# Application
APP_NAME=br-dev-jobs
DEBUG=false
LOG_LEVEL=INFO

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/brdevjobs

# Redis
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPERS=4
PLAYWRIGHT_HEADLESS=true

# Source URLs (override only if needed)
GUPY_API_URL=https://portal.api.gupy.io/api/job
REMOTEOK_RSS_URL=https://remoteok.com/remote-dev-jobs.rss

# Cache
CACHE_TTL_SECONDS=300
